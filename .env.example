# OpenAI credentials
OPENAI_API_KEY=your-openai-api-key

# Vector database provider. Default is chroma for local persistent storage.
VECTOR_DB_PROVIDER=chroma

# Chroma persistence directory for local vector storage.
CHROMA_PERSIST_DIRECTORY=./storage/chroma

# Embedding and LLM model configuration.
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o-mini

# Chunking parameters optimized for document intelligence.
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Set a default project namespace for document collections.
DEFAULT_PROJECT=energy-intelligence
